<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_heart_filled"
            android:contentDescription="Favorites icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favorites"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/widget_shuffle_favorites"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_shuffle"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Shuffle favorites"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Favorites Grid (2x3) -->
    <GridLayout
        android:id="@+id/widget_favorites_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="3"
        android:rowCount="2"
        android:useDefaultMargins="true">

        <!-- Favorite 1 -->
        <FrameLayout
            android:id="@+id/widget_fav_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <ImageView
                android:id="@+id/widget_fav_1_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/album_art_background"
                android:src="@drawable/widget_placeholder" />
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/favorite_overlay" />
        </FrameLayout>

        <!-- Favorite 2 -->
        <FrameLayout
            android:id="@+id/widget_fav_2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <ImageView
                android:id="@+id/widget_fav_2_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/album_art_background"
                android:src="@drawable/widget_placeholder" />
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/favorite_overlay" />
        </FrameLayout>

        <!-- Favorite 3 -->
        <FrameLayout
            android:id="@+id/widget_fav_3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <ImageView
                android:id="@+id/widget_fav_3_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/album_art_background"
                android:src="@drawable/widget_placeholder" />
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/favorite_overlay" />
        </FrameLayout>

        <!-- Favorite 4 -->
        <FrameLayout
            android:id="@+id/widget_fav_4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <ImageView
                android:id="@+id/widget_fav_4_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/album_art_background"
                android:src="@drawable/widget_placeholder" />
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/favorite_overlay" />
        </FrameLayout>

        <!-- Favorite 5 -->
        <FrameLayout
            android:id="@+id/widget_fav_5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <ImageView
                android:id="@+id/widget_fav_5_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/album_art_background"
                android:src="@drawable/widget_placeholder" />
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/favorite_overlay" />
        </FrameLayout>

        <!-- Favorite 6 / See All -->
        <FrameLayout
            android:id="@+id/widget_fav_6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="4dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/see_all_background" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="See All"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>

    </GridLayout>

</LinearLayout>